            .prose-yourgift h2 {
              color: rgba(255,255,255,0.95);
              font-size: 1.5rem;
              font-weight: 600;
              letter-spacing: -0.02em;
              margin-top: 2.5rem;
              margin-bottom: 1rem;
              line-height: 1.3;
            }
            .prose-yourgift h3 {
              color: rgba(255,255,255,0.88);
              font-size: 1.125rem;
              font-weight: 600;
              margin-top: 1.75rem;
              margin-bottom: 0.625rem;
              line-height: 1.4;
