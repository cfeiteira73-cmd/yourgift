# Database
DATABASE_URL=postgresql://user:password@localhost:5432/yourgift

# Stripe
STRIPE_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Suppliers
# Midocean API v2.0 — header: x-Gateway-APIKey — 2428 products confirmed live
MIDOCEAN_KEY=your-midocean-api-key-here
PF_CONCEPT_KEY=...
PF_CONCEPT_USER=...

# AWS
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=yourgift-assets
CLOUDFRONT_URL=https://cdn.yourgift.pt

# Auth
JWT_SECRET=...
JWT_EXPIRES_IN=7d

# API
API_URL=https://api.yourgift.pt
NEXT_PUBLIC_API_URL=https://api.yourgift.pt

# Email
RESEND_KEY=...
EMAIL_FROM=noreply@yourgift.pt

# OpenTelemetry (optional — omit to disable tracing)
# Endpoint for OTLP/HTTP exporter (e.g. Grafana Cloud, Honeycomb, Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com/v1/traces
OTEL_SERVICE_NAME=yourgift-api
OTEL_SERVICE_VERSION=1.0.0

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379

# Slack (optional — for incident alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Admin CLI scripts (scripts/chaos-drill.ts, failover-drill.ts, mfa-enroll.ts)
# Set to a valid admin JWT obtained from POST /admin-auth/login
YOURGIFT_ADMIN_TOKEN=eyJhbGc...

# Shadow Replay (terraform/shadow-replay/)
# URL of the staging API that receives replayed production traffic
SHADOW_STAGING_URL=https://staging-api.yourgift.pt
# Optional: API key added to replayed requests as X-Shadow-Key header
SHADOW_API_KEY=your-shadow-api-key

# Chaos engineering flags — set at runtime by chaos drills, not in normal config.
# Listed here for documentation only; do NOT set these in production .env.
# CHAOS_LATENCY_MS=500         # Injected by latency_injection drill
# CHAOS_STRIPE_TIMEOUT=1       # Injected by stripe_timeout drill
# CHAOS_REGION_ISOLATED=1      # Injected by full_region_isolation drill
