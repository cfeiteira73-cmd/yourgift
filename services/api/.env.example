# ═══════════════════════════════════════════════════════════════════════════
# YourGift OS — API Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# Rotate secrets every 90 days (see docs/secret-rotation.md)
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
# Supabase pooler (connection pool — use for runtime)
DATABASE_URL=postgresql://yourgift_app.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Direct connection (use for Prisma migrations only)
DIRECT_URL=postgresql://yourgift_app:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Supabase public keys
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Authentication ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your-secret-minimum-32-chars-change-me
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=https://yourgift-api.onrender.com/auth/callback/google

# ── Redis / BullMQ ─────────────────────────────────────────────────────────
# Upstash Redis (shared instance — prefix '{yourgift}' isolates our keys)
# Format: rediss://default:TOKEN@HOST:6379
UPSTASH_REDIS_URL=rediss://default:TOKEN@your-host.upstash.io:6379

# Fallback for local dev (docker run -p 6379:6379 redis:alpine)
# REDIS_URL=redis://localhost:6379

# ── Stripe ─────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Production keys: https://dashboard.stripe.com/apikeys
STRIPE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Alert email for failed payments / disputes
PAYMENT_ALERTS_EMAIL=ops@yourgift.pt

# ── Suppliers ──────────────────────────────────────────────────────────────
MIDOCEAN_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PF_CONCEPT_KEY=
PF_CONCEPT_USER=

# ── Email (Resend) ─────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourgift.pt

# ── AWS (S3 artwork storage) ────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=yourgift-assets
CLOUDFRONT_URL=https://cdn.yourgift.pt

# ── Observability ──────────────────────────────────────────────────────────
# Sentry DSN — get from https://sentry.io (Settings → Projects → Client Keys)
# Leave empty to disable Sentry (no-op in development)
SENTRY_DSN=https://xxxxx@oXXX.ingest.sentry.io/NNNNN
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── BetterStack ────────────────────────────────────────────────────────────
# Uptime heartbeat: betterstack.com → Monitors → New Heartbeat → copy URL
BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/TOKEN
# Logtail (structured logs): betterstack.com → Logs → Sources → copy token
BETTERSTACK_SOURCE_TOKEN=

# ── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
APP_VERSION=1.0.0

# ── Secret Rotation Schedule ────────────────────────────────────────────────
# JWT_SECRET          → rotate every 90 days (causes all sessions to expire)
# STRIPE_KEY          → rotate if compromised only (Stripe Support required)
# STRIPE_WEBHOOK_SECRET → regenerate in Stripe Dashboard → Webhooks
# RESEND_API_KEY      → rotate every 90 days
# SUPABASE_SERVICE_ROLE_KEY → rotate in Supabase Dashboard → Settings → API
# UPSTASH_REDIS_URL   → reset token in Upstash Console → Database → Token
# AWS keys            → rotate in IAM → rotate programmatically via AWS CLI
