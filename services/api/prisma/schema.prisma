model LedgerAccount {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  accountType   String   @map("account_type")   // asset | liability | revenue | expense | equity
  normalBalance String   @map("normal_balance")  // debit | credit
  description   String?
  isSystem      Boolean  @default(true) @map("is_system")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ledger_accounts")
}

model LedgerTransaction {
  id            String   @id @default(uuid())
  description   String
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")
  totalAmount   Float    @map("total_amount")
  currency      String   @default("EUR")
  tenantId      String   @default("default") @map("tenant_id")
  postedAt      DateTime @default(now()) @map("posted_at")

  entries LedgerEntry[]

  @@index([referenceType, referenceId])
  @@map("ledger_transactions")
}

model LedgerEntry {
  id              String   @id @default(uuid())
  transactionId   String   @map("transaction_id")
  accountCode     String   @map("account_code")
  entryType       String   @map("entry_type")   // debit | credit
  amount          Float
  currency        String   @default("EUR")
  description     String
  referenceType   String?  @map("reference_type")
  referenceId     String?  @map("reference_id")
  tenantId        String   @default("default") @map("tenant_id")
  postedAt        DateTime @default(now()) @map("posted_at")
  // IMMUTABLE: no updatedAt, append-only

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([accountCode])
  @@index([referenceType, referenceId])
  @@index([postedAt])
  @@index([tenantId])
  @@map("ledger_entries")
}

