model EmployeeWallet {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  tenantId      String   @default("default") @map("tenant_id")
  employeeEmail String   @map("employee_email")
  employeeName  String   @map("employee_name")
  department    String?
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  totalGranted  Decimal  @default(0) @map("total_granted") @db.Decimal(12, 2)
  totalSpent    Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  currency      String   @default("EUR")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transactions        WalletTransaction[]
  procurementRequests ProcurementRequest[]
  kitDeployments      KitDeployment[]

  @@unique([companyId, employeeEmail])
  @@index([tenantId])
  @@map("employee_wallets")
}

model WalletTransaction {
  id            String   @id @default(uuid())
  walletId      String   @map("wallet_id")
  type          String   // 'credit' | 'debit' | 'refund' | 'adjustment'
  amount        Decimal  @db.Decimal(12, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(12, 2)
  description   String
  referenceId   String?  @map("reference_id")
  referenceType String?  @map("reference_type")
  createdAt     DateTime @default(now()) @map("created_at")

  wallet EmployeeWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("wallet_transactions")
}

model OnboardingKit {
  id          String   @id @default(uuid())
  tenantId    String   @default("default") @map("tenant_id")
  name        String
  description String?
  department  String?
  totalValue  Decimal  @default(0) @map("total_value") @db.Decimal(12, 2)
  currency    String   @default("EUR")
  isActive    Boolean  @default(true) @map("is_active")
  items       Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  deployments KitDeployment[]

  @@index([tenantId])
  @@map("onboarding_kits")
}

model KitDeployment {
  id              String    @id @default(uuid())
  kitId           String    @map("kit_id")
  walletId        String    @map("wallet_id")
  tenantId        String    @default("default") @map("tenant_id")
  status          String    @default("pending") // pending | processing | shipped | delivered | cancelled
  employeeEmail   String    @map("employee_email")
  employeeName    String    @map("employee_name")
  shippingAddress Json      @default("{}") @map("shipping_address")
  totalCost       Decimal   @default(0) @map("total_cost") @db.Decimal(12, 2)
  notes           String?
  deployedAt      DateTime  @default(now()) @map("deployed_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  kit    OnboardingKit  @relation(fields: [kitId], references: [id])
  wallet EmployeeWallet @relation(fields: [walletId], references: [id])

  @@index([kitId])
  @@index([walletId])
  @@index([status])
  @@map("kit_deployments")
}

model ProcurementRequest {
  id              String    @id @default(uuid())
  walletId        String    @map("wallet_id")
  tenantId        String    @default("default") @map("tenant_id")
  companyId       String    @map("company_id")
  employeeEmail   String    @map("employee_email")
  department      String?
  productName     String    @map("product_name")
  productId       String?   @map("product_id")
  variantId       String?   @map("variant_id")
  quantity        Int       @default(1)
  unitPrice       Decimal?  @map("unit_price") @db.Decimal(12, 2)
