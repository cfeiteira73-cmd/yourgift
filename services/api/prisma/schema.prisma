generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  company      String?
  nif          String?
  passwordHash String?  @map("password_hash")
  tier         String   @default("standard")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  orders       Order[]

  @@map("clients")
}

model Product {
  id          String           @id @default(uuid())
  supplierRef String           @unique @map("supplier_ref")
  title       String
  description String
  category    String
  supplier    String
  basePrice   Float            @default(0) @map("base_price")
  images      String[]
  printAreas  Json             @default("{}") @map("print_areas")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  variants    ProductVariant[]
  orderItems  OrderItem[]

  @@index([category])
  @@index([supplier])
  @@map("products")
}

model ProductVariant {
  id             String      @id @default(uuid())
  productId      String      @map("product_id")
  sku            String      @unique
  color          String?
  colorGroup     String?     @map("color_group")
  colorCode      String?     @map("color_code")
  gtin           String?
  size           String?
  stock          Int         @default(0)
  price          Float       @default(0)
  images         String[]
  categoryLevel1 String?     @map("category_level1")
  categoryLevel2 String?     @map("category_level2")
  categoryLevel3 String?     @map("category_level3")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  product        Product     @relation(fields: [productId], references: [id])
  orderItems     OrderItem[]

  @@index([stock])
  @@map("product_variants")
}

model SyncLog {
  id               String   @id @default(uuid())
  supplier         String
  productsUpserted Int      @map("products_upserted")
  variantsUpserted Int      @map("variants_upserted")
  stockUpdated     Int      @map("stock_updated")
  errors           String[]
  durationMs       Int      @map("duration_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([supplier])
  @@map("sync_logs")
}

model Order {
  id              String      @id @default(uuid())
  ref             String      @unique
  clientId        String      @map("client_id")
  status          String      @default("pending")
  shippingAddress Json        @map("shipping_address")
  totalAmount     Float?      @map("total_amount")
  supplier        String?
  supplierOrderId String?     @map("supplier_order_id")
  stripeSessionId String?     @map("stripe_session_id")
  stripePaymentId String?     @map("stripe_payment_id")
  trackingNumber  String?     @map("tracking_number")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  client          Client      @relation(fields: [clientId], references: [id])
  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String         @id @default(uuid())
  orderId   String         @map("order_id")
  productId String         @map("product_id")
  variantId String         @map("variant_id")
  quantity  Int
  unitPrice Float          @map("unit_price")
  order     Order          @relation(fields: [orderId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}
