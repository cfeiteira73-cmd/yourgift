generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// CLIENTS & COMPANIES
// ─────────────────────────────────────────────

model Client {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  company      String?
  nif          String?
  passwordHash String?  @map("password_hash")
  tier         String   @default("standard") // standard | premium | enterprise
  companyId    String?  @map("company_id")
  tenantId     String   @default("default") @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders       Order[]
  quotes       Quote[]
  approvals    Approval[]
  companyRef   Company?   @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@map("clients")
}

model Company {
  id              String    @id @default(uuid())
  name            String
  nif             String?   @unique
  domain          String?   @unique
  logoUrl         String?   @map("logo_url")
  primaryColor    String?   @map("primary_color")
  tier            String    @default("standard") // standard | premium | enterprise
  billingEmail    String?   @map("billing_email")
  shippingAddress Json?     @map("shipping_address")
  tenantId        String    @default("default") @map("tenant_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  clients         Client[]
  departments     Department[]
  budgets         Budget[]
  companyStores   CompanyStore[]
  campaigns       Campaign[]
  orders          Order[]

  @@index([tenantId])
  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  headEmail String?  @map("head_email")
  createdAt DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [id])
  budgets   Budget[]
  orders    Order[]

  @@index([companyId])
  @@map("departments")
}

// ─────────────────────────────────────────────
// PRODUCTS & CATALOG
// ─────────────────────────────────────────────

model Product {
  id          String           @id @default(uuid())
  supplierRef String           @unique @map("supplier_ref")
  title       String
  description String
  category    String
  supplier    String           // midocean | pf_concept | stricker
  basePrice   Float            @default(0) @map("base_price")
  images      String[]
  printAreas  Json             @default("{}") @map("print_areas")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  variants          ProductVariant[]
  orderItems        OrderItem[]
  quoteItems        QuoteItem[]
  campaignItems     CampaignItem[]
  companyStoreItems CompanyStoreProduct[]
  inventoryAlerts   InventoryAlert[]

  @@index([category])
  @@index([supplier])
  @@map("products")
}

model ProductVariant {
  id             String      @id @default(uuid())
  productId      String      @map("product_id")
  sku            String      @unique
  color          String?
  colorGroup     String?     @map("color_group")
  colorCode      String?     @map("color_code")
  gtin           String?
  size           String?
  stock          Int         @default(0)
  price          Float       @default(0)
  images         String[]
  categoryLevel1 String?     @map("category_level1")
  categoryLevel2 String?     @map("category_level2")
  categoryLevel3 String?     @map("category_level3")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  product         Product          @relation(fields: [productId], references: [id])
  orderItems      OrderItem[]
  quoteItems      QuoteItem[]
  inventoryAlerts InventoryAlert[]

  @@index([stock])
  @@map("product_variants")
}

// ─────────────────────────────────────────────
// QUOTES / RFQ
// ─────────────────────────────────────────────

model Quote {
  id              String    @id @default(uuid())
  ref             String    @unique
  clientId        String    @map("client_id")
  companyId       String?   @map("company_id")
  departmentId    String?   @map("department_id")
  status          String    @default("draft")
  currency        String    @default("EUR")
  // draft | submitted | pricing | approved | rejected | converted
  eventDate       DateTime? @map("event_date")
  deliveryDate    DateTime? @map("delivery_date")
  notes           String?
  artworkUrl      String?   @map("artwork_url")
  pricingSnapshot Json?     @map("pricing_snapshot")
  totalAmount     Float?    @map("total_amount")
  marginAmount    Float?    @map("margin_amount")
  convertedOrderId String?  @unique @map("converted_order_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client   Client      @relation(fields: [clientId], references: [id])
  items    QuoteItem[]
  order    Order?      @relation(fields: [convertedOrderId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  productId   String   @map("product_id")
  variantId   String?  @map("variant_id")
  quantity    Int
  technique   String?  // embroidery | dtf | laser | pad | screen
  unitCost    Float?   @map("unit_cost")
  unitPrice   Float?   @map("unit_price")
  notes       String?

  quote   Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("quote_items")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String    @id @default(uuid())
  ref             String    @unique
  clientId        String    @map("client_id")
  companyId       String?   @map("company_id")
  departmentId    String?   @map("department_id")
  campaignId      String?   @map("campaign_id")
  status          String    @default("created")
  currency        String    @default("EUR")
  // created | paid | approved | producing | shipped | delivered | cancelled
  shippingAddress Json      @map("shipping_address")
  pricingSnapshot Json?     @map("pricing_snapshot")
  totalAmount     Float?    @map("total_amount")
  marginAmount    Float?    @map("margin_amount")
  supplier        String?
  supplierOrderId String?   @map("supplier_order_id")
  stripeSessionId String?   @map("stripe_session_id")
  stripePaymentId String?   @map("stripe_payment_id")
  trackingNumber  String?   @map("tracking_number")
  approvedAt      DateTime? @map("approved_at")
  approvedById    String?   @map("approved_by_id")
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  tenantId        String    @default("default") @map("tenant_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client      Client      @relation(fields: [clientId], references: [id])
  company     Company?    @relation(fields: [companyId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  campaign    Campaign?   @relation(fields: [campaignId], references: [id])
  items       OrderItem[]
  artworks    Artwork[]
  approvals   Approval[]
  eventLogs   EventLog[]
  quote       Quote?

  @@index([clientId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  variantId   String   @map("variant_id")
  quantity    Int
  unitCost    Float    @default(0) @map("unit_cost")
  unitPrice   Float    @map("unit_price")
  printCost   Float    @default(0) @map("print_cost")
  technique   String?

  order   Order          @relation(fields: [orderId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────
// ARTWORK & PROOFS
// ─────────────────────────────────────────────

model Artwork {
  id          String    @id @default(uuid())
  orderId     String    @map("order_id")
  filename    String
  originalUrl String    @map("original_url")
  s3Key       String    @map("s3_key")
  mimeType    String    @map("mime_type")
  sizeBytes   Int       @map("size_bytes")
  width       Int?
  height      Int?
  mockupUrl   String?   @map("mockup_url")
  status      String    @default("pending")
  // pending | approved | rejected | revision_requested
  reviewNotes String?   @map("review_notes")
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedById String?  @map("reviewed_by_id")
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("artworks")
}

// ─────────────────────────────────────────────
// BUDGETS
// ─────────────────────────────────────────────

model Budget {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  departmentId   String?   @map("department_id")
  name           String
  period         String    // monthly | quarterly | yearly | custom
  periodStart    DateTime  @map("period_start")
  periodEnd      DateTime  @map("period_end")
  limitAmount    Float     @map("limit_amount")
  spentAmount    Float     @default(0) @map("spent_amount")
  alertThreshold Float     @default(0.8) @map("alert_threshold") // 80% default
  alertSent      Boolean   @default(false) @map("alert_sent")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([companyId])
  @@index([departmentId])
  @@map("budgets")
}

// ─────────────────────────────────────────────
// APPROVALS
// ─────────────────────────────────────────────

model Approval {
  id           String    @id @default(uuid())
  orderId      String    @map("order_id")
  requestedById String   @map("requested_by_id")
  stage        String    // hr | manager | finance
  status       String    @default("pending") // pending | approved | rejected
  approvedById String?   @map("approved_by_id")
  notes        String?
  requestedAt  DateTime  @default(now()) @map("requested_at")
  resolvedAt   DateTime? @map("resolved_at")

  order       Order  @relation(fields: [orderId], references: [id])
  requestedBy Client @relation(fields: [requestedById], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("approvals")
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────

model Campaign {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  type        String    // onboarding_kit | event_kit | marketing_kit | custom
  description String?
  status      String    @default("draft") // draft | active | paused | completed
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Float?
  totalOrders Int       @default(0) @map("total_orders")
  totalSpent  Float     @default(0) @map("total_spent")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id])
  items   CampaignItem[]
  orders  Order[]

  @@index([companyId])
  @@index([status])
  @@map("campaigns")
}

model CampaignItem {
  id         String  @id @default(uuid())
  campaignId String  @map("campaign_id")
  productId  String  @map("product_id")
  quantity   Int
  unitPrice  Float?  @map("unit_price")
  notes      String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("campaign_items")
}

// ─────────────────────────────────────────────
// COMPANY STORES
// ─────────────────────────────────────────────

model CompanyStore {
  id              String    @id @default(uuid())
  companyId       String    @map("company_id")
  name            String
  slug            String    @unique
  logoUrl         String?   @map("logo_url")
  primaryColor    String?   @map("primary_color")
  secondaryColor  String?   @map("secondary_color")
  bannerUrl       String?   @map("banner_url")
  welcomeMessage  String?   @map("welcome_message")
  isActive        Boolean   @default(true) @map("is_active")
  allowedEmails   String[]  @map("allowed_emails") // domain whitelist
  monthlyBudget   Float?    @map("monthly_budget")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company   Company              @relation(fields: [companyId], references: [id])
  products  CompanyStoreProduct[]
  employees StoreEmployee[]

  @@index([companyId])
  @@map("company_stores")
}

model StoreEmployee {
  id          String    @id @default(uuid())
  storeId     String    @map("store_id")
  email       String
  name        String
  department  String?
  allowance   Float     @default(0)
  spent       Float     @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  store         CompanyStore           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders        EmployeeOrder[]
  ledgerEntries AllowanceLedgerEntry[]

  @@unique([storeId, email])
  @@index([storeId])
  @@map("store_employees")
}

model EmployeeOrder {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  storeId     String   @map("store_id")
  productId   String   @map("product_id")
  variantId   String?  @map("variant_id")
  quantity    Int
  totalAmount Float    @map("total_amount")
  status      String   @default("pending")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  employee StoreEmployee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([storeId])
  @@map("employee_orders")
}

model CompanyStoreProduct {
  id             String  @id @default(uuid())
  storeId        String  @map("store_id")
  productId      String  @map("product_id")
  customPrice    Float?  @map("custom_price")
  isAvailable    Boolean @default(true) @map("is_available")
  sortOrder      Int     @default(0) @map("sort_order")

  store   CompanyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@map("company_store_products")
}

// ─────────────────────────────────────────────
// SUPPLIER SYNC LOGS
// ─────────────────────────────────────────────

model SyncLog {
  id               String   @id @default(uuid())
  supplier         String
  productsUpserted Int      @map("products_upserted")
  variantsUpserted Int      @map("variants_upserted")
  stockUpdated     Int      @map("stock_updated")
  errors           String[]
  durationMs       Int      @map("duration_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([supplier])
  @@map("sync_logs")
}

// ─────────────────────────────────────────────
// EVENT LOG (AUDIT TRAIL)
// ─────────────────────────────────────────────

model EventLog {
  id        String   @id @default(uuid())
  orderId   String?  @map("order_id")
  entity    String   // order | quote | approval | budget | campaign | store
  entityId  String   @map("entity_id")
  event     String   // order.created | order.paid | order.approved | etc.
  actorId   String?  @map("actor_id")
  actorType String?  @map("actor_type") // client | admin | system
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([entity, entityId])
  @@index([event])
  @@index([createdAt])
  @@map("event_logs")
}

// ─────────────────────────────────────────────
// JOB QUEUE
// ─────────────────────────────────────────────

model Job {
  id          String    @id @default(uuid())
  type        String    // order.fulfill | artwork.process | notification.send | product.sync
  payload     Json      @default("{}")
  status      String    @default("pending") // pending | processing | completed | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  error       String?
  scheduledAt DateTime  @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@index([type])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// INVENTORY ALERTS
// ─────────────────────────────────────────────

model InventoryAlert {
  id           String    @id @default(uuid())
  variantId    String    @map("variant_id")
  productId    String    @map("product_id")
  alertType    String    @map("alert_type") // low_stock | out_of_stock | reorder_triggered
  threshold    Int       @default(10)
  currentStock Int       @map("current_stock")
  resolved     Boolean   @default(false)
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id])
  product Product        @relation(fields: [productId], references: [id])

  @@index([variantId])
  @@index([resolved])
  @@map("inventory_alerts")
}

// ─────────────────────────────────────────────
// ALLOWANCE LEDGER (append-only)
// ─────────────────────────────────────────────

model AllowanceLedgerEntry {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  storeId     String   @map("store_id")
  amount      Float                       // positive = credit (top-up), negative = debit (spend)
  balance     Float                       // running balance AFTER this entry
  entryType   String   @map("entry_type") // credit | debit | adjustment | refund | reset
  referenceId String?  @map("reference_id") // orderId, adminActionId, etc.
  description String
  actorId     String?  @map("actor_id")   // who performed the action
  actorType   String?  @map("actor_type") // employee | admin | system
  createdAt   DateTime @default(now()) @map("created_at")
  // IMMUTABLE: no updatedAt, no soft delete — this is append-only

  employee StoreEmployee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, createdAt])
  @@index([storeId])
  @@map("allowance_ledger")
}

// ─────────────────────────────────────────────
// PROCUREMENT EVENTS (event-sourcing stream)
// ─────────────────────────────────────────────

model ProcurementEvent {
  id          String   @id @default(uuid())
  streamId    String   @map("stream_id")    // entityId (orderId, quoteId, etc.)
  streamType  String   @map("stream_type")  // order | quote | campaign | employee_order
  eventType   String   @map("event_type")   // e.g. "order.status_changed"
  sequenceNum Int      @map("sequence_num") // monotonic per stream
  payload     Json     @default("{}")
  metadata    Json     @default("{}")       // actorId, actorType, correlationId, etc.
  appliedAt   DateTime @default(now()) @map("applied_at")
  // APPEND-ONLY: no updates, no deletes

  @@unique([streamId, sequenceNum])
  @@index([streamId, appliedAt])
  @@index([streamType, eventType])
  @@index([appliedAt])
  @@map("procurement_events")
}

// ─────────────────────────────────────────────
// PRICING RULES
// ─────────────────────────────────────────────

model PricingRule {
  id            String   @id @default(uuid())
  name          String
  ruleType      String   @map("rule_type") // volume | tier | client | product | category | supplier
  targetId      String?  @map("target_id")   // productId, clientId, category, supplier
  minQuantity   Int      @default(1) @map("min_quantity")
  maxQuantity   Int?     @map("max_quantity")
  discountType  String   @map("discount_type") // percentage | fixed | multiplier
  discountValue Float    @map("discount_value")
  marginMin     Float?   @map("margin_min")    // minimum margin % to enforce
  clientTier    String?  @map("client_tier")   // standard | premium | enterprise
  isActive      Boolean  @default(true) @map("is_active")
  priority      Int      @default(0)           // higher = applied first
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([ruleType, isActive])
  @@index([clientTier])
  @@map("pricing_rules")
}

// ─────────────────────────────────────────────
// OUTBOUND WEBHOOKS
// ─────────────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(uuid())
  companyId   String?  @map("company_id")
  url         String
  secret      String
  events      String[] // ["order.created", "order.paid", etc.]
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([companyId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String    @id @default(uuid())
  endpointId   String    @map("endpoint_id")
  event        String
  payload      Json
  statusCode   Int?      @map("status_code")
  responseBody String?   @map("response_body")
  success      Boolean   @default(false)
  attempts     Int       @default(0)
  deliveredAt  DateTime? @map("delivered_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([event])
  @@map("webhook_deliveries")
}

// ─────────────────────────────────────────────
// ADMIN USERS
// ─────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("manager") // admin | manager | viewer
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

// ─────────────────────────────────────────────
// FINANCIAL INTELLIGENCE
// ─────────────────────────────────────────────

model ClientFinancialSnapshot {
  id               String   @id @default(uuid())
  clientId         String   @map("client_id")
  companyId        String?  @map("company_id")
  periodMonth      String   @map("period_month")   // 'YYYY-MM'
  totalRevenue     Float    @default(0) @map("total_revenue")
  totalCost        Float    @default(0) @map("total_cost")
  grossMargin      Float    @default(0) @map("gross_margin")
  grossMarginPct   Float    @default(0) @map("gross_margin_pct")
  orderCount       Int      @default(0) @map("order_count")
  avgOrderValue    Float    @default(0) @map("avg_order_value")
  ltvCumulative    Float    @default(0) @map("ltv_cumulative")
  cacProxy         Float    @default(0) @map("cac_proxy")
  cohortMonth      String   @map("cohort_month")   // 'YYYY-MM' of first order
  computedAt       DateTime @default(now()) @map("computed_at")

  @@unique([clientId, periodMonth])
  @@index([clientId])
  @@index([companyId])
  @@index([periodMonth])
  @@index([cohortMonth])
  @@map("client_financial_snapshots")
}

model CompanyCohortAnalysis {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  cohortMonth          String   @map("cohort_month")
  periodMonth          String   @map("period_month")
  activeClients        Int      @default(0) @map("active_clients")
  totalOrders          Int      @default(0) @map("total_orders")
  totalRevenue         Float    @default(0) @map("total_revenue")
  avgRevenuePerClient  Float    @default(0) @map("avg_revenue_per_client")
  computedAt           DateTime @default(now()) @map("computed_at")

  @@unique([companyId, cohortMonth, periodMonth])
  @@index([companyId])
  @@index([periodMonth])
  @@map("company_cohort_analysis")
}

// ─────────────────────────────────────────────
// RETENTION LOOP ENGINE
// ─────────────────────────────────────────────

model ClientProcurementCycle {
  id                   String    @id @default(uuid())
