  createdAt DateTime  @default(now()) @map("created_at")
  @@index([clientId])
  @@map("refresh_tokens")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  @@index([email])
  @@map("magic_link_tokens")
}

model OAuthAccount {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  provider    String
  providerUid String   @map("provider_uid")
  email       String?
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  @@unique([provider, providerUid])
  @@index([clientId])
  @@map("oauth_accounts")
}

model AuthAuditLog {
  id        String   @id @default(cuid())
  clientId  String?  @map("client_id")
  email     String?
  action    String
  provider  String?
  ip        String?
  userAgent String?  @map("user_agent")
  success   Boolean  @default(true)
  errorMsg  String?  @map("error_msg")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([clientId])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

model AuthAttempt {
  id          String    @id @default(cuid())
  attemptId   String    @unique @map("attempt_id")
  provider    String
  status      String    @default("pending")
  clientId    String?   @map("client_id")
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@index([attemptId])
  @@index([createdAt])
  @@map("auth_attempts")
}

model DeviceSession {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  deviceId   String   @map("device_id")
  userAgent  String?  @map("user_agent")
  ip         String?
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  @@unique([clientId, deviceId])
  @@index([clientId])
  @@map("device_sessions")
}

model ActiveSession {
  id             String    @id @default(cuid())
  clientId       String    @map("client_id")
  deviceId       String?   @map("device_id")
  ip             String?
  userAgent      String?   @map("user_agent")
  provider       String?
  isActive       Boolean   @default(true) @map("is_active")
  revokedAt      DateTime? @map("revoked_at")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  @@index([clientId])
  @@index([isActive])
  @@map("active_sessions")
}

model AuthRiskEvent {
  id        String   @id @default(cuid())
  clientId  String?  @map("client_id")
  email     String?
  ip        String?
  deviceId  String?  @map("device_id")
  riskScore Int      @map("risk_score")
  riskLevel String   @map("risk_level")
  factors   Json     @default("{}")
  action    String
  provider  String?
  createdAt DateTime @default(now()) @map("created_at")
  @@index([clientId])
  @@index([ip])
  @@index([createdAt])
  @@map("auth_risk_events")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  plan      String   @default("free")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("organizations")
}

model UserOrganization {
  id             String    @id @default(cuid())
  clientId       String    @map("client_id")
  organizationId String    @map("organization_id")
  role           String    @default("member")
  joinedAt       DateTime? @map("joined_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  @@unique([clientId, organizationId])
  @@index([clientId])
  @@index([organizationId])
  @@map("user_organizations")
}

model AppPermission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("app_permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  role         String
  permissionId String @map("permission_id")
  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────
// BUDGET LEDGER + POLICY EXECUTION + PROCUREMENT WORKFLOW (Sprint 23)
// ─────────────────────────────────────────────

model BudgetAllocation {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  departmentId   String?  @map("department_id")
  period         String
  category       String?
  totalEur       Decimal  @map("total_eur") @db.Decimal(14, 2)
  reservedEur    Decimal  @default(0) @map("reserved_eur") @db.Decimal(14, 2)
  committedEur   Decimal  @default(0) @map("committed_eur") @db.Decimal(14, 2)
  spentEur       Decimal  @default(0) @map("spent_eur") @db.Decimal(14, 2)
  currency       String   @default("EUR")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  @@unique([organizationId, departmentId, period, category])
  @@index([organizationId])
  @@map("budget_allocations")
}

model BudgetTransaction {
  id                 String   @id @default(cuid())
  budgetAllocationId String   @map("budget_allocation_id")
  type               String
  amountEur          Decimal  @map("amount_eur") @db.Decimal(14, 2)
  referenceId        String?  @map("reference_id")
  referenceType      String?  @map("reference_type")
  note               String?
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  @@index([budgetAllocationId])
  @@index([referenceId])
  @@map("budget_transactions")
}

model WorkflowProcurementRequest {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default") @map("tenant_id")
  organizationId     String?   @map("organization_id")
  requesterId        String    @map("requester_id")
  status             String    @default("draft")
  title              String
  description        String?
  category           String?
  supplierCode       String?   @map("supplier_code")
  estimatedCostEur   Decimal?  @map("estimated_cost_eur") @db.Decimal(14, 2)
  actualCostEur      Decimal?  @map("actual_cost_eur") @db.Decimal(14, 2)
  quantity           Int?
  deliveryDays       Int?      @map("delivery_days")
  riskScore          Decimal?  @map("risk_score") @db.Decimal(5, 2)
  approvalChainId    String?   @map("approval_chain_id")
  currentStep        Int       @default(0) @map("current_step")
  budgetAllocationId String?   @map("budget_allocation_id")
  policyDecision     String?   @map("policy_decision")
  policyReason       String?   @map("policy_reason")
  approvedBy         String?   @map("approved_by")
  rejectedBy         String?   @map("rejected_by")
  rejectionReason    String?   @map("rejection_reason")
  fulfilledAt        DateTime? @map("fulfilled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @map("updated_at")
  @@index([tenantId])
  @@index([requesterId])
  @@index([status])
  @@index([organizationId])
  @@map("workflow_procurement_requests")
}

model OrgDepartment {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  code           String?
  parentId       String?  @map("parent_id")
  budgetLimitEur Decimal? @map("budget_limit_eur") @db.Decimal(14, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("org_departments")
}

model UserDepartment {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  departmentId String   @map("department_id")
  role         String   @default("member")
  createdAt    DateTime @default(now()) @map("created_at")
  @@unique([clientId, departmentId])
  @@index([departmentId])
  @@map("user_departments")
}

model IdentityDelegation {
  id             String    @id @default(cuid())
  delegatorId    String    @map("delegator_id")
  delegateeId    String    @map("delegatee_id")
  scope          String
  organizationId String?   @map("organization_id")
  budgetLimitEur Decimal?  @map("budget_limit_eur") @db.Decimal(14, 2)
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  @@index([delegatorId])
  @@index([delegateeId])
  @@index([isActive])
  @@map("identity_delegations")
}

model ApprovalChain {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  triggerType    String   @map("trigger_type")
  thresholdEur   Decimal? @map("threshold_eur") @db.Decimal(14, 2)
  category       String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  @@index([organizationId])
  @@index([triggerType])
  @@map("approval_chains")
}

model ApprovalChainStep {
  id              String   @id @default(cuid())
  approvalChainId String   @map("approval_chain_id")
  stepOrder       Int      @map("step_order")
  approverId      String?  @map("approver_id")
  approverRole    String?  @map("approver_role")
  timeoutHours    Int      @default(24) @map("timeout_hours")
  escalateTo      String?  @map("escalate_to")
  createdAt       DateTime @default(now()) @map("created_at")
  @@index([approvalChainId])
  @@map("approval_chain_steps")
}
