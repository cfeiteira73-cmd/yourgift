{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @yourgift/shared run build && pnpm --filter web run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/sync-prices",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-makito",
      "schedule": "0 3 * * 0"
    }
  ]
}
